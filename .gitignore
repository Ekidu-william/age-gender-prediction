# ============================================================
#  FaceAnalyzer AI — Root .gitignore
# ============================================================

# ── Images dataset (large, not for Git) ─────────────────────
images/
dataset/
data/
*.jpg
*.jpeg
*.png
*.webp

# ── Trained model files (large binary files) ────────────────
*.h5
*.keras
*.pt
*.pth
*.pb
*.tflite

# ── Generated CSV files ──────────────────────────────────────
train.csv
test.csv

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/

# ── Node.js ──────────────────────────────────────────────────
interface/node_modules/
interface/uploads/
interface/.env

# ── Training output ──────────────────────────────────────────
training_history.png
*.log

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini